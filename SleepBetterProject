import os
import shutil
import kagglehub

def download_project_datasets():
    """
    Downloads both the PSG Apnea Audios and the Snoring dataset natively
    using the kagglehub client library, then consolidates them locally.
    """
    # Create a local clean directory for your training files
    target_dir = "./local_dataset"
    os.makedirs(target_dir, exist_ok=True)
    
    print("⏳ Downloading PSG-Audio Apnea Audios dataset...")
    # Fetching: https://kaggle.com
    apnea_cache_path = kagglehub.dataset_download("bryandarquea/psg-audio-apnea-audios")
    print(f"✅ Apnea dataset cached at: {apnea_cache_path}")
    
    print("\n⏳ Downloading Snoring classification dataset...")
    # Fetching: https://kaggle.com
    snoring_cache_path = kagglehub.dataset_download("tareqkhanemu/snoring")
    print(f"✅ Snoring dataset cached at: {snoring_cache_path}")
    
    # Consolidate files from the kagglehub cache folder into your local repository workspace
    try:
        if os.path.exists(apnea_cache_path):
            shutil.copytree(apnea_cache_path, os.path.join(target_dir, "psg_apnea"), dirs_exist_ok=True)
        if os.path.exists(snoring_cache_path):
            shutil.copytree(snoring_cache_path, os.path.join(target_dir, "snoring_data"), dirs_exist_ok=True)
        print(f"\n🎉 Success! All training files are neatly consolidated inside: {os.path.abspath(target_dir)}")
    except Exception as e:
        print(f"⚠️ Files cached successfully, but local copy step failed: {e}")
        print("You can still use the raw cache paths directly in your training scripts.")

if __name__ == "__main__":
    # Setup Authentication: Ensure 'kaggle.json' is placed in your computer's '~/.kaggle/' path
    download_project_datasets()
import os
import base64
from flask import Flask, request, jsonify
from openai import OpenAI

app = Flask(__name__)

# 1. INITIALIZE OPENAI COMPATIBLE CLIENT FOR ALIBABA CONSOLE
# The client will pull your key natively from the 'DASHSCOPE_API_KEY' system variable.
# Switch baseURL to 'dashscope-intl.aliyuncs.com' if using an international/HK account tier.
client = OpenAI(
    api_key=os.getenv("DASHSCOPE_API_KEY"),
    base_url="https://dashscope.aliyuncs.com/compatible-mode/v1"
)

@app.route('/predict_apnea', methods=['POST'])
def predict_apnea():
    """
    Accepts binary .wav files uploaded directly via multipart form payloads from
    MIT App Inventor, forwards them to Qwen 3.5 Omni, and responds with clinical classifications.
    """
    # 2. FILE TRACK VALIDATION HANDSHAKE
    if 'audio' not in request.files:
        return jsonify({"status": "error", "message": "Missing audio block attachment payload"}), 400
        
    audio_file = request.files['audio']
    audio_bytes = audio_file.read()
    
    # Encode the binary audio file block to standard Base64 string formatting
    audio_b64_string = base64.b64encode(audio_bytes).decode('utf-8')
    
    # 3. CONSTRUCT OMNI MULTI-MODAL PROMPT OBJECT
    prompt_instruction = (
        "Analyze this user-submitted sleeping/snoring audio block track. "
        "Detect occurrences of respiratory cessation, micro-arousals, or gasping anomalies. "
        "Return your evaluation following this exact layout:\n"
        "Sleep Apnea Probability: [X]%\n"
        "Not Sleep Apnea (Normal): [Y]%"
    )
    
    try:
        print("📡 Forwarding App Inventor recording file straight to Qwen 3.5 Omni...")
        
        # 4. HANDSHAKE RUNTIME CALL
        completion = client.chat.completions.create(
            model="qwen3.5-omni-plus",
            messages=[
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": prompt_instruction},
                        {
                            "type": "input_audio",
                            "input_audio": {
                                "data": audio_b64_string,
                                "format": "wav"
                            }
                        }
                    ]
                }
            ],
            modalities=["text"], # Forces model to reply purely in clear text parameters
            temperature=0.1
        )
        
        # Extract the model text breakdown block
        analysis_report = completion.choices[0].message.content.strip()
        
        print("✅ Report generated successfully.")
        return jsonify({
            "status": "success",
            "report": analysis_report
        })
        
    except Exception as api_err:
        print(f"❌ Handshake failed: {api_err}")
        return jsonify({
            "status": "error",
            "message": str(api_err)
        }), 500

if __name__ == '__main__':
    # Binds port 5000 across all local adapters to welcome smartphone incoming connections
    app.run(host='0.0.0.0', port=5000, debug=True)

